{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AuthAPI",
  "description": "User registration and session JWT token retrieval contracts.",
  "endpoints": {
    "/api/auth/register": {
      "POST": {
        "description": "Register a new user account as client or coach.",
        "requestBody": {
          "type": "object",
          "properties": {
            "email": { "type": "string", "format": "email" },
            "password": { "type": "string", "minLength": 8 },
            "role": { "type": "string", "enum": ["COACH", "CLIENT"] }
          },
          "required": ["email", "password", "role"]
        },
        "responses": {
          "201": {
            "description": "User registered successfully.",
            "content": {
              "application/json": {
                "properties": {
                  "id": { "type": "string", "format": "uuid" },
                  "email": { "type": "string" },
                  "role": { "type": "string" }
                }
              }
            }
          },
          "400": { "description": "Email already in use or invalid payload." }
        }
      }
    },
    "/api/auth/login": {
      "POST": {
        "description": "Authenticate user credentials and retrieve a JWT access token.",
        "requestBody": {
          "type": "object",
          "properties": {
            "email": { "type": "string" },
            "password": { "type": "string" }
          },
          "required": ["email", "password"]
        },
        "responses": {
          "200": {
            "description": "Authentication successful.",
            "content": {
              "application/json": {
                "properties": {
                  "token": { "type": "string" },
                  "tokenType": { "type": "string", "const": "Bearer" },
                  "role": { "type": "string" }
                }
              }
            }
          },
          "401": { "description": "Invalid credentials." }
        }
      }
    }
  }
}
